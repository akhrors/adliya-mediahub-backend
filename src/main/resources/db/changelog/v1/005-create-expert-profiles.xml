<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="005-create-expert-profiles" author="adliya">
        <createTable tableName="expert_profiles">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="yonalishlar" type="TEXT"/>
            <!-- JSON array of directions e.g. ["davlat_xizmatlari","NHH","FHDY"] -->
            <column name="til_bilish" type="TEXT"/>
            <!-- JSON: {"uzbek":"YUQORI","rus":"ORTA","ingliz":"PAST"} -->
            <column name="tajriba" type="TEXT"/>
            <!-- JSON: ["TV","RADIO","INTERVYU","BRIFING"] -->
            <column name="reyting" type="DECIMAL(10,2)" defaultValueNumeric="0"/>
            <column name="status" type="VARCHAR(30)" defaultValue="FAOL">
                <constraints nullable="false"/>
                <!-- FAOL, VAQTINCHA_MAVJUD_EMAS, TAVSIYA_ETILMAYDI -->
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="expert_profiles"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_expert_user"/>
    </changeSet>

</databaseChangeLog>
