<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="004-create-media-outlets" author="adliya">
        <createTable tableName="media_outlets">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nomi" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="turi" type="VARCHAR(50)">
                <constraints nullable="false"/>
                <!-- TV, RADIO, INTERNET_NASHRI, GAZETA, JURNAL, BLOGER, BOSHQA -->
            </column>
            <column name="aloqa" type="VARCHAR(100)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="izoh" type="TEXT"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
